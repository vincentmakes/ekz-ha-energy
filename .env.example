# =============================================================================
# EKZ Energy Collector v5.0 — Configuration
# =============================================================================

# --- myEKZ Credentials (required) ---
EKZ_USERNAME=your.email@example.com
EKZ_PASSWORD=your_password_here

# Installation ID (optional — auto-discovered if left empty)
EKZ_INSTALLATION_ID=

# --- MQTT Broker (required) ---
MQTT_HOST=192.168.1.x
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Run Mode ---
# "daemon"   = run continuously (default, recommended)
# "oneshot"  = fetch once and exit
# "backfill" = fetch all history from BACKFILL_FROM, then exit
MODE=daemon

# Fetch interval in daemon mode (hours)
SCHEDULE_HOURS=4

# Days back for 15-min detail (2 = day before yesterday, more reliable)
FETCH_DAYS_BACK=2

# --- Backfill ---
# Start date for historical data fetch. On first daemon start with
# an empty cache, backfill runs automatically from this date.
BACKFILL_FROM=2025-01-01

# Delay between API calls in seconds (rate limiting)
API_DELAY_SECONDS=2

# --- HT/NT Classification ---
# Peak hours for HT/NT split when API doesn't provide tariffType
PEAK_HOUR_START=7
PEAK_HOUR_END=20

# --- HA Energy Dashboard (required for hourly resolution) ---
# For hourly bars in HA's built-in Energy Dashboard, provide your HA URL and
# a Long-Lived Access Token (Profile → Security → Long-Lived Access Tokens).
# Without these, the Energy Dashboard will only show one bar per fetch cycle.
#
# IMPORTANT: Use the IP address of your Home Assistant instance, not
# "homeassistant.local" or "localhost" — the container must be able to reach HA.
# Example: http://192.168.1.100:8123
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your_long_lived_access_token

# --- Optional ---
MQTT_TOPIC_PREFIX=ekz_energy
HA_DISCOVERY_PREFIX=homeassistant
LOG_LEVEL=INFO
